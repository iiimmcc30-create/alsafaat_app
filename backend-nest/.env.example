# ─────────────────────────────────────────────
# SARH Backend — Environment Variables Template
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://your-app-domain.com

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/sarh_db

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ─────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Network International (NI) Payment Gateway ───────────────────────────────
# Portal: https://portal.network.ae
# Documentation: https://docs.network.ae
#
# NI_BASE_URL:
#   Production → https://api-gateway.network.ae/networkapi/
#   Sandbox    → https://api-gateway.sandbox.network.ae/networkapi/
NI_BASE_URL=https://api-gateway.network.ae/networkapi/

# Your Outlet ID from the NI merchant portal (Settings → Outlets)
NI_OUTLET_ID=your_outlet_id_here

# API Key from NI portal (Settings → API Keys)
# Test keys start with "test_" — the app automatically switches to dev/sandbox mode
NI_API_KEY=your_ni_api_key_here

# Webhook secret for verifying NI webhook signatures
# Set this in NI portal → Webhooks → Secret Key
NI_WEBHOOK_SECRET=your_ni_webhook_secret_here

# ── Allowed CORS Origins ──────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8081,https://your-app-domain.com

# ── Storage / Media ──────────────────────────
STORAGE_URL=https://your-storage-bucket.com
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=me-south-1
AWS_BUCKET_NAME=sarh-media

# ── Notifications ─────────────────────────────
# Expo Push Notification Service (optional)
EXPO_ACCESS_TOKEN=

# ── Admin Seed ───────────────────────────────
ADMIN_EMAIL=admin@sarh.app
ADMIN_PASSWORD=change-me-in-production
