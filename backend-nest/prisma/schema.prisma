model SupportTicket {
  id           String         @id @default(uuid())
  ticketNumber String         @unique
  category     String
  priority     TicketPriority @default(NORMAL)
  status       TicketStatus   @default(OPEN)
  subject      String
  description  String
  adminNotes   String?
  reporterId   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  reporter     User?          @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([createdAt])
  @@index([deletedAt])
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  labelAr   String?
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContentSection {
  id        String    @id @default(uuid())
  slug      String    @unique
  titleAr   String
  titleEn   String?
  bodyAr    String
  bodyEn    String?
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum KnowledgeSourceType {
  RSS
  API
}

enum KnowledgeArticleStatus {
  PENDING
  PUBLISHED
  REJECTED
}

model KnowledgeSource {
  id        String              @id @default(uuid())
  name      String
  url       String
  type      KnowledgeSourceType @default(RSS)
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  articles  KnowledgeArticle[]
  syncLogs  KnowledgeSyncLog[]

  @@index([enabled])
  @@index([type])
}

model KnowledgeArticle {
  id            String                 @id @default(uuid())
  sourceId      String
  originalTitle String
  originalUrl   String                 @unique
  summary       String?
  titleAr       String?
  publishedAt   DateTime?
  status        KnowledgeArticleStatus @default(PENDING)
  postId        String?                @unique
  errorMessage  String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  source        KnowledgeSource        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  post          Post?                  @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([sourceId])
  @@index([status])
  @@index([publishedAt])
  @@index([createdAt])
}

model KnowledgeSyncLog {
  id        String           @id @default(uuid())
  sourceId  String?
  level     String
  message   String
  meta      Json?
  createdAt DateTime         @default(now())
  source    KnowledgeSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([sourceId])
  @@index([level])
}
