{
  "expo": {
    "name": "Sarh",
    "slug": "safat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "safat",
    "owner": "alsafa00",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.safat.app",
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "CFBundleDisplayName": "سرح | Sarh"
      }
    },
    "android": {
      "package": "com.safat.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.WAKE_LOCK",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#284E39"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-circle.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#163526"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "نحتاج الوصول لمكتبة الصور لتغيير صورة البروفايل والغلاف"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "نحتاج موقعك لتحديد مكان الملحمة على الخريطة"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#006B3C",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-asset",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/flaticon/rr.ttf",
            "./assets/fonts/flaticon/sr.ttf",
            "./assets/fonts/flaticon/br.ttf"
          ]
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fc410a8a-09ab-49bb-ba66-53c86471e9aa"
      }
    }
  }
}
