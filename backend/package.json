{
  "name": "safat-backend",
  "version": "1.0.0",
  "description": "SAFAT Backend — Next.js API + Socket.IO + PostgreSQL + Redis",
  "scripts": {
    "dev": "next dev --port 3001 -H 0.0.0.0",
    "build": "next build",
    "start": "next start --port 3001",
    "socket": "node -r dotenv/config dist/socket-server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run socket:dev\"",
    "socket:dev": "nodemon --exec \"ts-node -r dotenv/config -r tsconfig-paths/register src/socket-server.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "worker": "ts-node -r dotenv/config -r tsconfig-paths/register src/workers/index.ts",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:push": "prisma db push",
    "db:setup": "prisma generate && prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "create-admin": "ts-node scripts/create-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.521.0",
    "@aws-sdk/s3-request-presigner": "^3.521.0",
    "@prisma/client": "^5.10.0",
    "@sentry/nextjs": "^7.107.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@upstash/redis": "^1.28.0",
    "agora-token": "^2.0.5",
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.4.0",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "next": "^14.1.0",
    "next-connect": "^1.0.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.11",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "rate-limiter-flexible": "^5.0.0",
    "sharp": "^0.33.2",
    "socket.io": "^4.7.4",
    "socket.io-redis": "^6.1.1",
    "twilio": "^6.0.2",
    "uuid": "^9.0.1",
    "winston": "^3.12.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.22.4"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.20",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "19.2.17",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
